# Tushare Pro API Token
# Register at https://tushare.pro and get your token
TUSHARE_TOKEN=your_token_here

# MiniMax API Key (for AI analysis)
MINIMAX_API_KEY=your_minimax_api_key

# Tavily API Key (for web search in stock trend analysis)
# Get from https://tavily.com
TAVILY_API_KEY=your_tavily_api_key

# LangSmith Tracing (for agent observability)
# Enable tracing: https://smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=stock_analysis
